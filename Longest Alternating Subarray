class Solution:
    def minNumber(self, nums1: List[int], nums2: List[int]) -> int:
        set1 = set(nums1)
        set2 = set(nums2)

        common = set1.intersection(set2)

        if common:
            return min(common)
        else:
            min1 = min(nums1)
            min2 = min(nums2)

            small = min(min1,min2)
            large = max(min1,min2)
            
            return small*10 + large
